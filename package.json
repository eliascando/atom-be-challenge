{
  "name": "taskexpress-functions-api",
  "version": "1.0.0",
  "private": true,
  "description": "API de tareas y usuarios con TypeScript, Azure Functions y Firestore, organizada con separación de capas inspirada en arquitectura limpia y puertos/adaptadores.",
  "main": "lib/functions/index.js",
  "engines": {
    "node": "^20 || ^22"
  },
  "scripts": {
    "clean": "rimraf lib coverage",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "npm run build && func start",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/functions": "^4.12.0",
    "bcryptjs": "^3.0.3",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
